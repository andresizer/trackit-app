# ============================================================
# VARIÁVEIS DE AMBIENTE — App de Controle Financeiro
# ============================================================
# Copie este arquivo para .env.local e preencha os valores

# ============================================================
# DATABASE
# ============================================================
# PostgreSQL connection string
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Exemplo local: postgresql://postgres:postgres@localhost:5432/financeiro
# Exemplo Vercel: fornecido automaticamente pelo Vercel Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ============================================================
# NEXTAUTH (Autenticação)
# ============================================================
# Secret para assinar tokens JWT — gere com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-aqui-minimo-32-caracteres"

# URL base da aplicação (usado pelo NextAuth para callbacks)
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.com
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# OAUTH PROVIDERS (opcional — para login social)
# ============================================================
# Google OAuth
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (opcional)
# Obtenha em: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================================
# ANTHROPIC API (Claude — recursos de IA)
# ============================================================
# API Key da Anthropic para categorização, resumos e alertas
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Modelo a ser usado (padrão: claude-sonnet-4-20250514)
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ============================================================
# TELEGRAM BOT API (MVP)
# ============================================================
# Token do bot Telegram — obtenha conversando com @BotFather
# 1. Envie /newbot para @BotFather
# 2. Siga as instruções
# 3. Copie o token fornecido
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"

# URL do webhook (Telegram enviará mensagens para esta URL)
# Desenvolvimento: use ngrok ou similar
# Produção: https://seu-dominio.com/api/webhooks/telegram
TELEGRAM_WEBHOOK_URL="https://seu-dominio.com/api/webhooks/telegram"

# ============================================================
# WHATSAPP CLOUD API (Futuro — após aprovação da Meta)
# ============================================================
# Deixe vazio por enquanto — será preenchido após aprovação
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_WEBHOOK_URL="https://seu-dominio.com/api/webhooks/whatsapp"

# ============================================================
# OUTRAS CONFIGURAÇÕES
# ============================================================
# Ambiente (development, production, test)
NODE_ENV="development"

# URL pública da aplicação (para gerar links em e-mails, bot, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Moeda padrão (ISO 4217)
NEXT_PUBLIC_DEFAULT_CURRENCY="BRL"

# Timezone padrão
NEXT_PUBLIC_DEFAULT_TIMEZONE="America/Sao_Paulo"
